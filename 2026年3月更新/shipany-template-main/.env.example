# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_PROVIDER = "sqlite"
DATABASE_URL = "file:data/local.db"
DB_SCHEMA_FILE = "./src/config/db/schema.sqlite.ts"
DB_MIGRATIONS_OUT = "./src/config/db/migrations_sqlite"
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY = ""
STRIPE_WEBHOOK_SECRET = ""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY = ""

# ── Alipay（支付宝）────────────────────────────────────────────────────────────
# 在支付宝开放平台 https://open.alipay.com 创建应用后获取
ALIPAY_APP_ID = ""
# RSA2 私钥（PKCS8 格式，换行用 \n）
ALIPAY_PRIVATE_KEY = ""
# 支付宝公钥（非应用公钥，从开放平台「查看支付宝公钥」页面获取）
ALIPAY_PUBLIC_KEY = ""
# 沙箱时改为 https://openapi.alipaydev.com/gateway.do
ALIPAY_GATEWAY = "https://openapi.alipay.com/gateway.do"

# ── WeChat Pay（微信支付）v3 ────────────────────────────────────────────────────
# 在微信商户平台 https://pay.weixin.qq.com 申请 Native 支付后获取
WECHAT_APP_ID = ""
WECHAT_MCH_ID = ""
# 商户私钥（PEM 格式，换行用 \n）
WECHAT_PRIVATE_KEY = ""
# 商户证书公钥（PEM 格式，换行用 \n）
WECHAT_PUBLIC_KEY = ""
# 商户 API 证书序列号
WECHAT_SERIAL_NO = ""
# APIv3 密钥（32位字符串，用于回调解密）
WECHAT_API_V3_KEY = ""